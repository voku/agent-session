#!/usr/bin/env php
<?php

declare(strict_types=1);

use voku\AgentSession\Cli;

spl_autoload_register(static function (string $class): void {
    $prefix = 'voku\\AgentSession\\';
    if (!str_starts_with($class, $prefix)) {
        return;
    }

    $path = __DIR__ . '/../src/' . str_replace('\\', '/', substr($class, strlen($prefix))) . '.php';
    if (is_file($path)) {
        require $path;
    }
});

if (class_exists(Cli::class)) {
    exit((new Cli())->run($argv));
}

$autoloadCandidates = [
    __DIR__ . '/../vendor/autoload.php',
    __DIR__ . '/../../../autoload.php',
    getcwd() . '/vendor/autoload.php',
];

foreach ($autoloadCandidates as $autoloadCandidate) {
    if (is_file($autoloadCandidate)) {
        require $autoloadCandidate;
        exit((new Cli())->run($argv));
    }
}

fwrite(STDERR, "Cannot find Composer autoload file for voku/agent-session.\n");
exit(1);
