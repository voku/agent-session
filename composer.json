{
  "name": "voku/agent-session",
  "description": "Working-memory layer for coding agents: per-task session plans, decisions, assumptions, checkpoints, claim metadata, and retention.",
  "type": "library",
  "license": "MIT",
  "homepage": "https://github.com/voku/agent-session",
  "support": {
    "issues": "https://github.com/voku/agent-session/issues",
    "source": "https://github.com/voku/agent-session"
  },
  "authors": [
    {
      "name": "Lars Moelleken",
      "homepage": "https://github.com/voku"
    }
  ],
  "require": {
    "php": "^8.3"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "psr-4": {
      "voku\\AgentSession\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "voku\\AgentSession\\Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/agent-session"
  ],
  "scripts": {
    "test": "phpunit",
    "phpstan": "phpstan analyse --configuration=phpstan.neon.dist --memory-limit=512M",
    "ci": [
      "@composer validate --strict",
      "@test",
      "@phpstan"
    ]
  },
  "config": {
    "allow-plugins": false,
    "sort-packages": true
  },
  "extra": {
    "branch-alias": {
      "dev-main": "0.1.x-dev"
    }
  }
}
